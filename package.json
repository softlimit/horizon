{
  "name": "softlimit-horizon",
  "version": "1.0.0",
  "description": "[Getting started](#getting-started) | [Staying up to date with Horizon changes](#staying-up-to-date-with-horizon-changes) | [Developer tools](#developer-tools) | [Contributing](#contributing) | [License](#license)",
  "main": "index.js",
  "scripts": {
    "pull": "shopify theme pull --store=sl-dev-testing.myshopify.com",
    "pull-json": "shopify theme pull --store=sl-dev-testing.myshopify.com --only=templates/*.json --only=sections/*.json --only=config/settings_data.json --only=locales/*",
    "push": "shopify theme push --store=sl-dev-testing.myshopify.com --ignore=locales/* --ignore=templates/*.json --ignore=templates/**/*.json --ignore=sections/*.json --ignore=config/settings_data.json --ignore=package.json --nodelete",
    "push-all": "shopify theme push --store=sl-dev-testing.myshopify.com --ignore=package.json --nodelete",
    "push-unpublished": "shopify theme push -u --store=sl-dev-testing.myshopify.com --ignore=package.json",
    "start": "shopify theme dev --store=sl-dev-testing.myshopify.com --ignore=package.json"
  },
  "author": "",
  "license": "ISC"
}
